# ==== Copy to backend/.env and fill in. NEVER commit real keys. ====

# --- LLM chat (DeepSeek via LangChain ChatOpenAI, OpenAI-compatible API) ---
CHAT_API_BASE=https://mkp-api.fptcloud.com/v1
CHAT_API_KEY=sk-REPLACE_ME
CHAT_MODEL=DeepSeek-V4-Flash
CHAT_STRUCTURED_METHOD=prompt # FPT DeepSeek: JSON instructions, no response_format=json_object

# Fallback nếu DeepSeek vỡ JSON/tiếng Việt kém (đổi 3 dòng trên thành):
# CHAT_API_BASE=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini

# --- Optional post-MVP FPT Vietnamese Embedding; release không cần ---
# EMBED_API_BASE=https://mkp-api.fptcloud.com/v1
# EMBED_API_KEY=sk-REPLACE_ME
# EMBED_MODEL=Vietnamese_Embedding
# EMBED_DIMENSIONS=1024
# EMBED_INPUT_TYPE=passage
# EMBED_INPUT_TEXT_TRUNCATE=none

# --- App ---
DATABASE_URL=sqlite:///./market.db
SESSIONS_DB_URL=sqlite:///./sessions.db
CORS_ORIGINS=http://localhost:3000
DEMO_MODE=off            # off | replay  (replay = trả cached responses, không gọi LLM)
AGENT_MODE=langgraph     # release path; switch to deterministic for emergency fallback

# Optional tuning (Graduate Launch readiness band; not hiring probability)
READINESS_READY_COVERAGE=0.75
READINESS_NEAR_COVERAGE=0.45
READINESS_MIN_EVIDENCE_SKILLS=2

# --- Frontend (đặt trong frontend/.env.local) ---
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_USE_MOCK=0
