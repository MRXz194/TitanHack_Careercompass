# Railway Variables — copy values in Dashboard; never commit real keys.
CHAT_API_BASE=https://mkp-api.fptcloud.com/v1
CHAT_API_KEY=REPLACE_IN_RAILWAY_DASHBOARD
CHAT_MODEL=DeepSeek-V4-Flash
CHAT_STRUCTURED_METHOD=prompt

EMBED_API_BASE=https://mkp-api.fptcloud.com/v1
EMBED_API_KEY=REPLACE_IN_RAILWAY_DASHBOARD
EMBED_MODEL=Vietnamese_Embedding
EMBED_DIMENSIONS=1024
EMBED_INPUT_TYPE=passage
EMBED_INPUT_TEXT_TRUNCATE=none

DATABASE_URL=sqlite:///./market.db
SESSIONS_DB_URL=sqlite:///./sessions.db
CORS_ORIGINS=https://REPLACE-WITH-VERCEL-PRODUCTION-DOMAIN
DEMO_MODE=off
AGENT_MODE=langgraph
WEB_RESEARCH_MODE=replay
WEB_RESEARCH_TIMEOUT_SECONDS=4
WEB_RESEARCH_MAX_RESULTS=5
WEB_RESEARCH_CACHE_TTL_SECONDS=900

READINESS_READY_COVERAGE=0.75
READINESS_NEAR_COVERAGE=0.45
READINESS_MIN_EVIDENCE_SKILLS=2
